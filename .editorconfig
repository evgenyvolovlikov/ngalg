root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{ts,tsx,js,jsx,html,htm,svg,scss,sass,css}]
indent_style = space
indent_size = 2

[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = unset
indent_size = unset

[*.{lock,pnpm-lock.yaml}]
indent_style = unset
indent_size = unset
