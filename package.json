  "scripts": {
    "ng": "ng",
    "lint": "ng lint",
    "start:dev": "pnpm ng serve",
    "build:dev": "pnpm ng build --configuration development",
    "watch:build:dev": "pnpm ng build --watch --configuration development",
    "start:prod": "pnpm ng serve --configuration production",
    "build:prod": "pnpm ng build --configuration production",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,css,json}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,html,scss,css,json}\"",
    "lint:check": "ng lint",
    "lint:fix": "ng lint --fix",
    "lint:styles": "stylelint \"src/**/*.{css,scss}\"",
    "lint:styles:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "validate": "pnpm lint:check && pnpm lint:styles && pnpm format:check",
    "prepare": "husky",
    "storybook": "ng run ngalg:storybook",
    "build-storybook": "ng run ngalg:build-storybook"
  }
